AJS.toInit(function() {
	define("MacroSize", function () {
		return {
			"S": {
				width: 320,
				height: 180
			},
			"M": {
				width: 640,
				height: 360
			},
			"L": {
				width: 800,
				height: 450
			}
		};
	});
});
