try {
/* module-key = 'de.dl.confluence.plugin.imagemap.ImageMapPlugin:scroll-imagemap-webresources', location = '/com/k15t/scroll/imagemap/macro/imagemap-editor.js' */
;(function(SPARK) {

    require(['jquery', 'ajs'], function($, AJS) {

        'use strict';

        // Refactoring needed to use newer SPARK methods / fullscreen dialog:
        //  - ImageMapSparkServlet should extend AtlassianIframeContentServlet
        //  - here SPARK.iframeAppLoader.openFullscreenIframeDialog should be used
        //  - in the app itself (loaded in the iframe), SPARK.getDialogControls() should be used insead of
        //          parentWindow['scroll-imagemap-spark'].dialog
        //      - requires changes in scroll-imagemap-ui/src/app/common/confluence-server-service.ts
        //  - also editor.html needs to be renamed to index.html, or SPARK updated, because only the index.html file
        //          will get a special treatment adding eg the iframe content window side of iframe-resizer and SPARK controls
        //      - can be done eg by setting scroll-imagemap-ui/webpack-common.js to have 'filename': 'index.html' for
        //          template 'src/editor.html'
        //      - changing the name of this file will require updating also atlassian-connect.json (remember also to keep editor.html there
        //          too for the roll-out period)

        var initImageMapEditor = function() {

            if (window.Scroll === undefined) window.Scroll = {};
            if (window.Scroll.ImageMap === undefined) window.Scroll.ImageMap = {};

            // the 'apploader' in SPARK used for legacy support does not set the content window part of SPARK
            // so we need to reach out to the SPARK in host window to eg close the dialog
            // store a namespaced reference to the correct version of SPARK to be able to do that
            window.Scroll.ImageMap.SPARK = SPARK;
            window.Scroll.ImageMap.params = AJS.params;
            window.Scroll.ImageMap.baseUrl = AJS.Meta.get('base-url');
            window.Scroll.ImageMap.contextPath = AJS.contextPath();

            var macroOverride = {
                opener: function(macro) {

                    window.Scroll.ImageMap.macro = macro;

                    SPARK.iframeAppLoader.openFullscreenIframeDialog(
                        'imagemap-app',
                        '/plugins/servlet/scroll-imagemap/editor.html',
                        {}
                    );
                }
            };

            // there are some cases when our storageToEditor transformer is not executed for existing pages when updating to new ImageMap
            // version, possibly if there is a live draft - do the overrides also with old name to be sure

            AJS.MacroBrowser.setMacroJsOverride('scroll-imagemap', macroOverride);
            AJS.MacroBrowser.setMacroJsOverride('scroll-imagemap-macro', macroOverride);

            // We want to show the "Placeholder Chrome" (a grey box around the image that shows that this is a Macro). The normal way to do
            // it is to set "applyPlaceholderChrome" to true on the ImagePlaceholder returned by the Macro class. Unfortunately that shows
            // not only the macro name, but also the macro parameters in the header of the box, which we don't want (because it contains
            // unreadable JSON).
            // The way that Confluence implements this is that it sets a background-image on the Macro Placeholder image. The background image
            // is created by a web service that receives the base64-encoded Macro definition and generates the placeholder from it. So we
            // simply apply this background image manually here and pass the Macro definition without any parameters to the web service.

            var setMacroHeaderOverride = function(macroName, macroDefinition) {
                var ed = AJS.Rte.getEditor();
                var locale = AJS.Meta.get('user-locale');
                $('<style type="text/css">img[data-macro-name=' + macroName + '] {' +
                    'background-position: 0 0 !important; background-repeat: no-repeat !important; padding: 24px 2px 2px 2px !important; max-width: 650px; height: auto;' +
                    'background-image: url(' + AJS.Meta.get('context-path') +
                    '/plugins/servlet/confluence/placeholder/macro-heading?definition=' + macroDefinition + '&locale=' + locale +
                    ') !important;' +
                    '}</style>').appendTo(ed.getDoc().head);
            };


            var macroDefinitionScrollImageMap = 'e3Njcm9sbC1pbWFnZW1hcH0='; // btoa('{scroll-imagemap}')
            var macroDefinitionScrollImageMapMacro = 'e3Njcm9sbC1pbWFnZW1hcC1tYWNyb30'; // btoa('{scroll-imagemap-macro}')

            setMacroHeaderOverride('scroll-imagemap', macroDefinitionScrollImageMap);
            setMacroHeaderOverride('scroll-imagemap-macro', macroDefinitionScrollImageMapMacro);

        };

        AJS.toInit(function() {
            if (!AJS.Editor.currentEditMode) {
                AJS.bind('init.rte', initImageMapEditor);
            } else {
                initImageMapEditor();
            }
        });

    });

})(getSpark());

}catch(e){WRMCB(e)};
;
