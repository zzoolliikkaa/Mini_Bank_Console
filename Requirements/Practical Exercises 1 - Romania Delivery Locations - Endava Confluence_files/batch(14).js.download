try {
/* module-key = 'com.mxgraph.confluence.plugins.plantuml:plantuml-rte', location = 'js/plantUmlCloudEditor.js' */
// bind on initialization of editor
AJS.bind("init.rte", function () {

    AJS.MacroBrowser.setMacroJsOverride('plantumlcloud', {
        opener: function (macro) {
            var pageId;
            if (AJS.params.newPage) {
                pageId = AJS.params.draftId;
            } else {
                pageId = AJS.params.pageId;
            }
			var contextPath = document.querySelector('meta[name="ajs-context-path"]').getAttribute('content');

            window.addEventListener('message', function (event) {
                event.stopImmediatePropagation();
                var macroPayload = null;

                try {
                    macroPayload = JSON.parse(event.data)
                } catch (e) {
                    return;
                }
                if (macroPayload.action === 'completeMacro') {
                    let macroData = {
                        name: 'plantumlcloud',
                        params: macroPayload.data
                    }
                    tinymce.confluence.macrobrowser.macroBrowserComplete(macroData);
                    removeIFrame();
                }
                if (macroPayload.action === 'closeMacro') {
					tinymce.confluence.macrobrowser.macroBrowserCancel();
                    removeIFrame();
                }                

            });
            window.pantUmlMacro = macro;
            window.editorPageId = pageId;
            window.ioContextPath = contextPath;

            openIframe();

        }
    });

    function openIframe() {
        var editorUrl = AJS.contextPath() + "/plugins/plantumlcloud/editPlantUMLDiagram.action";
        var editorFrame = $('<iframe id="plantumlEditor">');
        editorFrame.appendTo('body');
        editorFrame.css({
            "position": "fixed",
            "width": "100%",
            "height": "100%",
            "top": "0px",
            "left": "0px",
            "border-style": "none",
            "zIndex": 1001
        });
        editorFrame.attr("src", editorUrl);
    };

    function removeIFrame() {
        var frame = document.getElementById("plantumlEditor");
        frame.parentNode.removeChild(frame);
    }
});

}catch(e){WRMCB(e)};
;
