try {
/* module-key = 'com.realtimeboard.plugins.confluence-server-plugin:confluence-server-editor-resources', location = '/js/editor-main.js' */
AJS.toInit(function ($) {
	window.miroBoardsPicker = null;

	require(['MacroSize'], function(MacroSize) {
		var oldParams;
		function updateMacro(param, event, macroNode) {
			var $macroDiv = AJS.$(macroNode);
			var macroParams = (function(macroNode) { return AJS.MacroBrowser.getMacroParams(macroNode); } || getMacroParamsPolyfill)(macroNode);
			var size = MacroSize[param];

			AJS.Rte.getEditor().selection.select($macroDiv[0]);
			AJS.Rte.BookmarkManager.storeBookmark();

			macroParams.Width = size.width;
			macroParams.Height = size.height;

			var macroRenderRequest = {
				contentId: Confluence.Editor.getContentId(),
				macro: {
					name: "miro",
					params: macroParams
				}
			};

			tinymce.confluence.MacroUtils.insertMacro(macroRenderRequest);
		}

		function getMacroParamsPolyfill($macroNode) {
			var dataMacroParams = $macroNode.attributes.getNamedItem("data-macro-parameters").value;

			var params = [];
			var temp = "";
			for (var i = 0; i < dataMacroParams.length; i++) {
				var c = dataMacroParams[i];
				if (c === "\\") {
					//temp += c;
					if (i + 1 !== dataMacroParams.length) {
						temp += dataMacroParams[++i];
					}
				} else if (c === "|") {
					params.push(temp);
					temp = "";
				} else {
					temp += c;
				}
			}
			params.push(temp);
			return convertMacroParamsToObject(params);
		}

		function convertMacroParamsToObject(params) {
			var result = {};
			for(var i = 0; i < params.length; i++) {
				var index = params[i].indexOf('=');
				if (index > 1) {
					result[params[i].substring(0, index)] = decodeURIComponent(params[i].substring(index + 1));
				}
			}
			return result;
		}

		function openPicker(macro) {
			oldParams = macro.params;
			window.miroBoardsPicker.open({
				clientId: '3074457347683351961',
				action: 'access-link',
				embedMode: 'view_only_without_ui',
				success: function (result) {
					var macroData = {
						BoardTitle: result.name,
						AccessLink: result.accessLink,

						Width: (oldParams || {}).Width || MacroSize.M.width,
						Height: (oldParams || {}).Height || MacroSize.M.height
					};

					tinymce.confluence.macrobrowser.macroBrowserComplete({
						name: 'miro',
						params: macroData
					});
				}
			});
		}

		AJS.MacroBrowser.setMacroJsOverride('miro', {
			opener:function (macro) {
				if (!window.miroBoardsPicker) {
					var boardsPickerScript = document.createElement('script');
					boardsPickerScript.src = 'https://miro.com/app/static/boardsPicker.1.0.js'
					document.head.appendChild(boardsPickerScript)
					boardsPickerScript.addEventListener('load', function () {
						document.head.removeChild(boardsPickerScript)
						openPicker(macro)
					})
				} else {
					openPicker(macro)
				}
			}
		});

		// AJS.Confluence.PropertyPanel.Macro.registerInitHandler(function(macroPlaceholder, buttons) {
		//
		// }, 'miro');

		AJS.Confluence.PropertyPanel.Macro.registerButtonHandler("s", updateMacro.bind(null, 'S'));
		AJS.Confluence.PropertyPanel.Macro.registerButtonHandler("m", updateMacro.bind(null, 'M'));
		AJS.Confluence.PropertyPanel.Macro.registerButtonHandler("l", updateMacro.bind(null, 'L'));
	});
});
}catch(e){WRMCB(e)};
;
